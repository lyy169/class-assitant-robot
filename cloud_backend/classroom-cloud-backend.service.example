[Unit]
Description=Classroom Cloud Backend Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/video_project
EnvironmentFile=-/root/video_project/cloud_backend/.env
ExecStart=/root/venv/bin/uvicorn cloud_backend.main:app --host 0.0.0.0 --port 8010
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
