# Raspberry Pi client runtime configuration template.
# Copy to .env on the device and fill real values locally.

USE_DEEPSEEK=true
USE_OPENAI=false
USE_SPARK=false

SILICONFLOW_API_KEY=
OPENAI_API_KEY=
SPARK_API_APPID=
SPARK_API_SECRET=
SPARK_API_KEY=

AZURE_SPEECH_KEY=

HTTP_PROXY=
HTTPS_PROXY=

CHAT_OR_STANDARD=true
USE_ONLINE_RECOGNIZE=true

SNOWBOY_ENABLE=true
SNOWBOY_PATH=./snowboy
SNOWBOY_FORCE_SPEECH_FALLBACK=true

GPIO_WAKE_ENABLE=false

PI_CAPTURE_ROOT=captures
PI_CAPTURE_DELIVERY_MODE=shared_dir
PI_LOCAL_DELIVERY_ROOT=captures_local_delivery
PI_CAPTURE_PID_FILE=captures/.capture_session.pid
PI_CAPTURE_STATE_FILE=captures/.capture_session_state.json
PI_CAPTURE_CAMERA_ID=0
PI_CAPTURE_AUDIO_DEVICE_INDEX=-1
PI_CAPTURE_VIDEO_FPS=25
PI_CAPTURE_FRAME_WIDTH=1280
PI_CAPTURE_FRAME_HEIGHT=720
PI_DEFAULT_CLASSROOM_ID=classroom-default
PI_DEVICE_ID=
PI_DEVICE_NAME=

KEYFRAME_CAMERA_ID=0
KEYFRAME_RECEIVER_URL=http://127.0.0.1:8000/api/keyframes
